# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Claude API (AI brain)
ANTHROPIC_API_KEY=your-claude-api-key

# Twilio (SMS + A2P registration)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Vapi (outbound AI voice calls)
VAPI_API_KEY=your-vapi-api-key
VAPI_ASSISTANT_ID=your-assistant-id

# ElevenLabs (in-browser voice)
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=your-agent-id

# GoHighLevel (CRM)
GHL_API_KEY=your-ghl-api-key
GHL_LOCATION_ID=your-location-id
GHL_COMPANY_ID=your-company-id
GHL_SNAPSHOT_ID=your-snapshot-id

# Widget
NEXT_PUBLIC_WIDGET_URL=https://app.leadrwizard.com/onboard

# Cron
CRON_SECRET=your-cron-secret

# Escalation
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/xxx

# Google Business Profile
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=your-google-refresh-token

# Vercel (website hosting)
VERCEL_TOKEN=your-vercel-token
VERCEL_TEAM_ID=your-vercel-team-id
